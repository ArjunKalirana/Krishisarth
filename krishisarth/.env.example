# KrishiSarth Infrastructure Environment Variables

# PostgreSQL Configuration
POSTGRES_USER=krishisarth         # Database user
POSTGRES_PASSWORD=password        # Database password (CHANGE IN PROD)
POSTGRES_DB=krishisarth           # Relational database name

# InfluxDB Configuration
INFLUXDB_USERNAME=admin           # InfluxDB admin username
INFLUXDB_PASSWORD=password        # InfluxDB admin password (CHANGE IN PROD)
INFLUXDB_ORG=krishisarth          # InfluxDB organization name
INFLUXDB_BUCKET=krishisarth_sensors # Time-series bucket name (defined in PROJECT_RULES.md)
INFLUXDB_RETENTION=90d            # Data retention period (90 days as per PROJECT_SPEC.md)
INFLUXDB_TOKEN=my-super-secret-token # Admin token for API access

# Redis Configuration
REDIS_PORT=6379

# MQTT Configuration (Mosquitto)
MQTT_PORT=1883
MQTT_WS_PORT=9001
